  <Code>Public Function BlankZero(ByVal Value As Decimal)
    if Value = 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankPos(ByVal Value As Decimal)
    if Value &gt; 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankZeroAndPos(ByVal Value As Decimal)
    if Value &gt;= 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankNeg(ByVal Value As Decimal)
    if Value &lt; 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankNegAndZero(ByVal Value As Decimal)
    if Value &lt;= 0 then
        Return ""
    end if
    Return Value
End Function

Shared DataSrc as Object

Public Function GetData(Num as Integer) as Object
   Return Cstr(Choose(Num, Split(Cstr(DataSrc),Chr(177))))
End Function

Public Function SetData(NewData as Object) as Boolean
  If NewData &lt;&gt; ""
     DataSrc = NewData
  End If
  Return True
End Function</Code>
